PORT=8080

POSTGRES_DB=faithlog
POSTGRES_USER=faithlog
POSTGRES_PASSWORD=faithlog

SPRING_PROFILES_ACTIVE=docker
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/faithlog
SPRING_DATASOURCE_USERNAME=faithlog
SPRING_DATASOURCE_PASSWORD=faithlog
SPRING_DATASOURCE_HIKARI_MAXIMUM_POOL_SIZE=5
SPRING_FLYWAY_ENABLED=false
SPRING_JPA_HIBERNATE_DDL_AUTO=update

SPRING_DATA_REDIS_HOST=redis
SPRING_DATA_REDIS_PORT=6379

PGADMIN_DEFAULT_EMAIL=admin@faithlog.dev
PGADMIN_DEFAULT_PASSWORD=faithlog

JWT_SECRET=replace-with-docker-dev-secret
JWT_ACCESS_TOKEN_VALIDITY_SECONDS=1800
JWT_REFRESH_TOKEN_VALIDITY_SECONDS=1209600

FIREBASE_CONFIG_PATH=
FIREBASE_CONFIG_JSON=
FAITHLOG_SCHEDULER_ENABLED=false
