{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faithlog.local/performance/issue-197/devotion-fixture-manifest.schema.json",
  "title": "FaithLog Issue #197 devotion write fixture manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "scenarioType",
    "datasetId",
    "fixtureRunId",
    "referenceDate",
    "campusId",
    "rollbackCampusId",
    "warmupWeekStartDate",
    "measuredWeekStartDate",
    "rollbackWeekStartDate",
    "expectedMeasuredUserCount",
    "expectedPenaltyAmount",
    "warmupUserIds",
    "measuredUserIds",
    "rollbackUserIds"
  ],
  "properties": {
    "scenarioType": { "const": "devotion-write" },
    "datasetId": { "type": "string", "pattern": "^PERFORMANCE_" },
    "fixtureRunId": { "type": "string", "pattern": "^ISSUE197_" },
    "referenceDate": { "type": "string", "format": "date" },
    "campusId": { "type": "integer", "minimum": 1 },
    "rollbackCampusId": { "type": "integer", "minimum": 1 },
    "warmupWeekStartDate": { "type": "string", "format": "date" },
    "measuredWeekStartDate": { "type": "string", "format": "date" },
    "rollbackWeekStartDate": { "type": "string", "format": "date" },
    "expectedMeasuredUserCount": { "const": 1000 },
    "expectedPenaltyAmount": { "type": "integer", "minimum": 1 },
    "warmupUserIds": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/userId" }
    },
    "measuredUserIds": {
      "type": "array",
      "minItems": 1000,
      "maxItems": 1000,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/userId" }
    },
    "rollbackUserIds": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/userId" }
    }
  },
  "$defs": {
    "userId": { "type": "integer", "minimum": 1 }
  }
}
