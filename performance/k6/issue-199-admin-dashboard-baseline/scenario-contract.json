{
  "issue": 199,
  "status": "scenario-ready/not-measured",
  "endpoint": {
    "method": "GET",
    "path": "/api/v1/admin/campuses/{campusId}/dashboard/summary",
    "queryParameters": [
      {
        "name": "weekStartDate",
        "required": false,
        "format": "YYYY-MM-DD Monday"
      }
    ]
  },
  "runtimeTarget": {
    "baseUrlAndAppContainerRequired": true,
    "publishedPortMustMatch": true,
    "serviceLabelsFromManifestMustMatch": ["app", "postgres", "redis"]
  },
  "authorization": {
    "allowed": [
      "service-admin",
      "active-campus-minister",
      "active-campus-elder",
      "active-campus-leader"
    ],
    "denied": [
      "plain-member",
      "other-campus-admin",
      "global-manager-only"
    ],
    "deniedCode": "ADMIN_DASHBOARD_ACCESS_FORBIDDEN"
  },
  "frontendEntry": {
    "orderedSteps": [
      "POST /api/v1/auth/login",
      "parallel GET /api/v1/users/me + GET /api/v1/campuses/me",
      "GET /api/v1/admin/campuses/{campusId}/dashboard/summary?weekStartDate={weekStartDate}"
    ],
    "productionParallelSiblings": [
      "admin campus members",
      "duty assignments",
      "prayer weekly board",
      "campus detail for invite code"
    ],
    "measurementIsolation": "Each selected dataset mode uses a warmup token, then refreshes a measured JWT immediately before the pure DB counter snapshot and validates exp against measured duration plus an approved safety. Measured k6 setup performs no HTTP, and only dashboard summary is measured."
  },
  "dataset": {
    "modes": [
      "empty",
      "small",
      "thousand"
    ],
    "identifiers": [
      "datasetId",
      "fixtureRunId"
    ],
    "thousandMemberCount": 1000,
    "fixtureDomains": [
      "devotion",
      "penalty",
      "coffee",
      "meal",
      "poll",
      "prayer"
    ],
    "seedPolicy": "reference-only"
  },
  "runSelection": {
    "datasetModesRuntimeRequired": true,
    "allowlist": ["empty", "small", "thousand"],
    "duplicatesAllowed": false,
    "existingModeReportDirectory": "fail-closed"
  },
  "metrics": [
    "p50",
    "p95",
    "p99",
    "max",
    "throughput",
    "failureRate"
  ],
  "adoptionGate": {
    "warmupAndMeasuredFailureRate": 0,
    "requestCountMustBePositive": true,
    "throughputMustExistAndBePositive": true,
    "requiredLatencyStatistics": ["p50", "p95", "p99", "max"],
    "latencyThreshold": "not-user-approved",
    "dbWindow": "required tables/planner exact; monotonic deltas; stable stats_reset/analyze/autoanalyze/planner; no external activity"
  },
  "correctness": [
    "member active/inactive/admin counts",
    "devotion submitted/missing/rate",
    "UNPAID PENALTY/COFFEE amount and member totals",
    "OPEN and recently CLOSED poll counts",
    "per-OPEN-poll response counts and aggregate missing count",
    "same-campus data only and other-campus denial"
  ],
  "evidence": [
    "warmup and measured k6 summaries",
    "Docker CPU and RAM snapshots",
    "pure pre/post pg_stat_database and pg_stat_user_tables counter snapshots with observer-overhead interpretation metadata",
    "machine-readable DB correctness with exact per-OPEN-poll response counts",
    "out-of-window analyze/autoanalyze and fixture context",
    "optional pg_stat_statements query evidence",
    "planner settings",
    "machine-gated external activity declaration and pg_stat_activity snapshots",
    "matching actual Compose project/service labels and a shared Compose-project runner lock"
  ]
}
