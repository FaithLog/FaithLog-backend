SERVER_PORT=8080
PORT=8080

POSTGRES_DB=faithlog
POSTGRES_USER=faithlog
POSTGRES_PASSWORD=change-me

SPRING_PROFILES_ACTIVE=local
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/faithlog
SPRING_DATASOURCE_USERNAME=faithlog
SPRING_DATASOURCE_PASSWORD=change-me
SPRING_DATASOURCE_HIKARI_MAXIMUM_POOL_SIZE=5
SPRING_FLYWAY_ENABLED=false
SPRING_JPA_HIBERNATE_DDL_AUTO=update

SPRING_DATA_REDIS_HOST=redis
SPRING_DATA_REDIS_PORT=6379

PGADMIN_DEFAULT_EMAIL=admin@faithlog.dev
PGADMIN_DEFAULT_PASSWORD=change-me

JWT_SECRET=replace-with-at-least-32-byte-secret
JWT_ACCESS_TOKEN_VALIDITY_SECONDS=3600
JWT_REFRESH_TOKEN_VALIDITY_SECONDS=1209600

FIREBASE_CONFIG_PATH=
FIREBASE_CONFIG_JSON=

# Cloud Run / Supabase production contract example. Do not put real values in this file.
# SPRING_PROFILES_ACTIVE=prod
# SPRING_DATASOURCE_URL=jdbc:postgresql://<supabase-host>:5432/<database>?sslmode=require
# SPRING_DATASOURCE_USERNAME=<supabase-database-user>
# SPRING_DATASOURCE_PASSWORD=<supabase-database-password>
# SPRING_DATASOURCE_HIKARI_MAXIMUM_POOL_SIZE=5
# SPRING_FLYWAY_ENABLED=true
# SPRING_JPA_HIBERNATE_DDL_AUTO=validate
# SPRING_DATA_REDIS_HOST=<redis-host>
# SPRING_DATA_REDIS_PORT=6379
# JWT_SECRET=<changeme-strong-secret>
# FIREBASE_CONFIG_JSON=<firebase-admin-json-as-secret>
